// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

enum ServiceStatus {
  DITERIMA
  DIAGNOSA
  DIKERJAKAN
  MENUNGGU_SPAREPART
  SELESAI
  DIBATALKAN
}

enum WarrantyStatus {
  MENUNGGU
  DIPROSES
  SELESAI
  DITOLAK
}

model ServiceRequest {
  id              String        @id @default(cuid())
  trackingId      String        @unique
  name            String
  whatsapp        String
  address         String
  deviceType      String
  serviceType     String
  problemDesc     String
  scheduleDate    DateTime
  status          ServiceStatus @default(DITERIMA)
  technicianName  String?
  technicianNotes String?

  sparepartUsages SparepartUsage[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  diagnosedAt     DateTime?
  workingAt       DateTime?
  completedAt     DateTime?

  @@index([status])
  @@index([createdAt])
}

model ServiceContent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String?
  icon        String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sparepart {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  price       Int
  stock       Int      @default(0)
  imageUrl    String?
  isFeatured  Boolean  @default(false)
  
  usages      SparepartUsage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SparepartUsage {
  id               String         @id @default(cuid())
  serviceRequestId String
  sparepartId      String
  quantity         Int            @default(1)
  
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  sparepart        Sparepart      @relation(fields: [sparepartId], references: [id], onDelete: Restrict)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([serviceRequestId])
  @@index([sparepartId])
}

model Promo {
  id          String   @id @default(cuid())
  slug        String   @unique
  badge       String
  title       String
  description String
  validUntil  String
  terms       String
  howToClaim  String
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String
  deviceType  String
  problemType String
  beforeImage String
  afterImage  String
  completionDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  imageUrl    String
  author      String
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id          String   @id // e.g., "terms", "privacy"
  content     String
  updatedAt   DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarrantyClaim {
  id          String         @id @default(cuid())
  name        String
  whatsapp    String
  trackingId  String
  description String
  status      WarrantyStatus @default(MENUNGGU)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([trackingId])
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  rating     Int
  comment    String
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
