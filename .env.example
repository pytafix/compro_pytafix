# Database (Neon PostgreSQL)
POSTGRES_PRISMA_URL="postgresql://user:password@host:port/db?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:port/db?sslmode=require"

# Admin Authentication
ADMIN_PASSWORD="your-strong-admin-password-here"
JWT_SECRET="your-64-char-hex-jwt-secret-here"

# Google Cloud (optional, for development)
GOOGLE_APPLICATION_CREDENTIALS="google-service-account.json"

# Vercel (set via Vercel dashboard, not needed locally)
# VERCEL_OIDC_TOKEN=""